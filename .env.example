# Copy to .env at the repository root and fill in. Never commit .env.
#
# Generate a fresh key with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=replace-me
DEBUG=True
LOG_LEVEL=INFO
BRAND_NAME=Resumatch
TIME_ZONE=UTC

# Comma-separated. Left empty in DEBUG, where localhost is assumed.
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Omit for local SQLite. On a PaaS this is provided for you.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Object storage for resume files. Required in production: PaaS disks are
# ephemeral, so local MEDIA_ROOT loses uploads on every restart.
USE_S3=False
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=auto
# AWS_S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com

# Optional. Falls back to in-process memory caching.
# REDIS_URL=redis://localhost:6379/0

ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
RESUME_MAX_BYTES=5242880

THROTTLE_AUTH=10/min
THROTTLE_SCORING=20/min
THROTTLE_UPLOAD=20/hour
